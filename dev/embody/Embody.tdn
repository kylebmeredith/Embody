	"type_defaults": {
		"textDAT": {
			"parameters": {
				"syncfile": true
			},
			"color": [0.9, 0.3, 0.4]
		},
		"containerCOMP": {
			"parameters": {
				"resizecomp": "=me",
				"repocomp": "=me"
			},
			"color": [0.3, 0.5, 0.9],
			"tags": ["tdn"]
		},
		"parameterexecuteDAT": {
			"parameters": {
				"fromop": "=parent()",
				"syncfile": true
			},
			"size": [130, 90],
			"color": [0.9, 0.3, 0.4],
			"tags": ["py"]
		},
		"textCOMP": {
			"parameters": {
				"vmode": "fill",
				"resizecomp": "=me",
				"repocomp": "=me"
			},
			"size": [160, 130],
			"color": [0.3, 0.5, 0.9],
			"tags": ["tdn"]
		},
		"panelexecuteDAT": {
			"parameters": {
				"fromop": "=parent()",
				"panelvalue": "*",
				"ontooff": true,
				"valuechange": true,
				"syncfile": true
			},
			"size": [130, 90],
			"color": [0.9, 0.3, 0.4],
			"tags": ["py"]
		},
		"tableDAT": {
			"parameters": {
				"syncfile": true
			},
			"size": [130, 90],
			"color": [0.9, 0.3, 0.4],
			"tags": ["tsv"]
		},
		"annotateCOMP": {
			"parameters": {
				"order": "=me.digits or 0",
				"layerzone": "=0 if hasattr(me, 'EncloseOPs') and me.EncloseOPs else 1"
			},
			"flags": ["display"],
			"color": [0.45, 0.45, 0.45]
		}
	},
